# Panel admin: nginx sirve estaticos + proxy /api y /static a la API.
# Context de build: membrillo_portal/
FROM nginx:alpine
COPY admin/ /usr/share/nginx/html/
COPY deploy/nginx/admin.conf /etc/nginx/conf.d/default.conf
RUN printf 'window.API_BASE="/api";\n' > /usr/share/nginx/html/assets/config.js
EXPOSE 80
