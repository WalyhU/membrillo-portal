# Frontend e-commerce: nginx sirve estaticos + proxy /api y /static a la API.
# Context de build: membrillo_portal/
FROM nginx:alpine
COPY web/ /usr/share/nginx/html/
COPY deploy/nginx/web.conf /etc/nginx/conf.d/default.conf
# En K8s la API es mismo origen via proxy -> config apunta a /api (sin CORS).
RUN printf 'window.API_BASE="/api";\n' > /usr/share/nginx/html/assets/config.js
EXPOSE 80
